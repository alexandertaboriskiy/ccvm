<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ccvm.tunnel</string>
  <key>ProgramArguments</key>
  <array>
    <!-- Update this path if you installed ccvm-tunnel elsewhere -->
    <string>/Users/YOU/bin/ccvm-tunnel</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/ccvm-tunnel.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/ccvm-tunnel.log</string>
  <key>ThrottleInterval</key>
  <integer>30</integer>
</dict>
</plist>
