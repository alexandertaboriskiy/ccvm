#!/bin/bash
# ccvm - Cloud Code VM
# Resumes suspended GCE VM, SSHs in, manages tmux sessions per project,
# and starts your preferred AI coding agent (Claude Code or Gemini CLI).
#
# Usage:
#   ccvm                              # connect to VM, land in ~/cloud-projects/
#   ccvm --my-project                 # open default agent in ~/cloud-projects/my-project/
#   ccvm --my-project --env=gemini    # open Gemini CLI
#   ccvm --my-project --env=claude    # open Claude Code
#   ccvm --delete=my-project          # kill tmux session and remove project folder
#   ccvm ls                           # list projects and active tmux sessions
#   ccvm upload --my-project f1 f2    # upload files to a project folder
#   ccvm download --my-project f1     # download file from a project folder

# --- Configuration (edit these) ---
PROJECT="my-project"
ZONE="europe-west6-a"
INSTANCE="ccvm"
PROJECTS_DIR="cloud-projects"

DEFAULT_ENV="claude"
CLAUDE_CMD="claude --dangerously-skip-permissions --model opus"
GEMINI_CMD="gemini --yolo --model gemini-3.1-pro-preview"
# ---

# Subcommand
COMMAND="$1"

# Help
if [ "$COMMAND" = "help" ] || [ "$COMMAND" = "-h" ] || [ "$COMMAND" = "--help" ]; then
  cat <<'EOF'
ccvm - Cloud Code VM

Connect:
  ccvm                              Connect to VM, land in ~/cloud-projects/
  ccvm --myproject                  Open Claude Code in ~/cloud-projects/myproject/
  ccvm --myproject --env=gemini     Open Gemini CLI instead
  ccvm --myproject --env=claude     Open Claude Code (default)

Projects:
  ccvm ls                           List projects and active tmux sessions
  ccvm --delete=myproject           Kill tmux session and remove project folder
  ccvm --delete=proj1,proj2         Delete multiple projects

File transfer:
  ccvm upload --myproject f1 f2     Upload local files to project folder
  ccvm download --myproject f1      Download file from project folder to cwd

iTerm2 drag-and-drop:
  Option+drag file onto terminal    Upload file via SCP to current remote dir

Keyboard shortcuts (inside tmux):
  Ctrl+D                            Detach from tmux (session stays alive)
  Ctrl+B, D                         Detach from tmux (alternative)
  Prefix+m                          Toggle mouse mode (for drag-and-drop)
EOF
  exit 0
fi

# Parse arguments
SESSION=""
DELETE=""
ENV="$DEFAULT_ENV"
for arg in "$@"; do
  if [[ "$arg" == --env=* ]]; then
    ENV="${arg#--env=}"
  elif [[ "$arg" == --delete=* ]]; then
    DELETE="${arg#--delete=}"
  elif [[ "$arg" == --* ]]; then
    SESSION="${arg#--}"
  fi
done

# Select command based on env
case "$ENV" in
  claude)  AGENT_CMD="$CLAUDE_CMD" ;;
  gemini)  AGENT_CMD="$GEMINI_CMD" ;;
  *)
    echo "Unknown env: $ENV. Supported: claude, gemini"
    exit 1
    ;;
esac

# Resume/start VM if needed (short timeout avoids hanging on stale network connections)
STATUS=$(timeout 10 gcloud compute instances describe "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --format="value(status)" 2>/dev/null)
if [ $? -eq 124 ]; then
  echo "Timed out checking VM status. Retrying..."
  STATUS=$(gcloud compute instances describe "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --format="value(status)" 2>/dev/null)
fi

case "$STATUS" in
  RUNNING)
    echo "VM is running. Connecting..."
    ;;
  SUSPENDED)
    echo "VM is suspended. Resuming..."
    gcloud compute instances resume "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --quiet
    echo "Waiting for VM to be ready..."
    while true; do
      S=$(gcloud compute instances describe "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --format="value(status)" 2>/dev/null)
      [ "$S" = "RUNNING" ] && break
      sleep 2
    done
    sleep 5
    # Verify SSH is actually reachable — network sometimes fails after resume
    echo "Verifying SSH connectivity..."
    SSH_OK=false
    for i in $(seq 1 6); do
      if gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" --command='true' 2>/dev/null; then
        SSH_OK=true
        break
      fi
      sleep 5
    done
    if [ "$SSH_OK" = false ]; then
      echo "SSH unreachable after resume (network likely failed). Resetting VM..."
      gcloud compute instances reset "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --quiet
      echo "Waiting for VM to come back..."
      sleep 10
      for i in $(seq 1 12); do
        if gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" --command='true' 2>/dev/null; then
          break
        fi
        sleep 10
      done
    fi
    echo "VM is ready. Connecting..."
    ;;
  TERMINATED|STOPPED)
    echo "VM is stopped. Starting..."
    gcloud compute instances start "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --quiet
    echo "Waiting for VM to be ready..."
    while true; do
      S=$(gcloud compute instances describe "$INSTANCE" --zone="$ZONE" --project="$PROJECT" --format="value(status)" 2>/dev/null)
      [ "$S" = "RUNNING" ] && break
      sleep 2
    done
    sleep 10
    echo "VM is ready. Connecting..."
    ;;
  *)
    echo "VM status: $STATUS. Cannot connect."
    exit 1
    ;;
esac

# --- Subcommands ---

# List projects and sessions
if [ "$COMMAND" = "ls" ]; then
  gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" --command='
    echo "Projects:"
    ls -1 ~/'"$PROJECTS_DIR"' 2>/dev/null || echo "  (none)"
    echo ""
    echo "Active tmux sessions:"
    tmux list-sessions 2>/dev/null || echo "  (none)"
  '
  exit 0
fi

# Upload files to project folder
if [ "$COMMAND" = "upload" ]; then
  if [ -z "$SESSION" ]; then
    echo "Usage: ccvm upload --project file1 [file2 ...]"
    exit 1
  fi
  shift  # remove "upload"
  FILES=()
  for arg in "$@"; do
    [[ "$arg" != --* ]] && FILES+=("$arg")
  done
  if [ ${#FILES[@]} -eq 0 ]; then
    echo "No files specified."
    exit 1
  fi
  gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" --command="mkdir -p ~/$PROJECTS_DIR/$SESSION"
  gcloud compute scp "${FILES[@]}" "$INSTANCE:~/$PROJECTS_DIR/$SESSION/" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT"
  exit 0
fi

# Download files from project folder
if [ "$COMMAND" = "download" ]; then
  if [ -z "$SESSION" ]; then
    echo "Usage: ccvm download --project file1 [file2 ...]"
    exit 1
  fi
  shift  # remove "download"
  for arg in "$@"; do
    [[ "$arg" != --* ]] && gcloud compute scp "$INSTANCE:~/$PROJECTS_DIR/$SESSION/$arg" . --tunnel-through-iap --zone="$ZONE" --project="$PROJECT"
  done
  exit 0
fi

# Delete projects (comma-separated list)
if [ -n "$DELETE" ]; then
  IFS=',' read -ra TO_DELETE <<< "$DELETE"
  for P in "${TO_DELETE[@]}"; do
    echo "Deleting project '$P'..."
    gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" --command='
      tmux kill-session -t ='"$P"' 2>/dev/null && echo "  Killed tmux session: '"$P"'" || echo "  No tmux session: '"$P"'"
      if [ -d ~/'"$PROJECTS_DIR/$P"' ]; then
        rm -rf ~/'"$PROJECTS_DIR/$P"'
        echo "  Removed folder: ~/'"$PROJECTS_DIR/$P"'"
      else
        echo "  No folder: ~/'"$PROJECTS_DIR/$P"'"
      fi
    '
  done
  exit 0
fi

# --- Connect ---

if [ -z "$SESSION" ]; then
  # No project — run first-time setup if needed, list projects, land in projects dir
  gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" -- -t '
    if [ ! -f ~/.ccvm-setup-done ]; then
      bash ~/first-run-setup.sh
    fi
    mkdir -p ~/'"$PROJECTS_DIR"'
    echo "Projects:"
    ls -1 ~/'"$PROJECTS_DIR"' 2>/dev/null || echo "  (none)"
    echo ""
    cd ~/'"$PROJECTS_DIR"' && exec bash
  '
else
  REMOTE_DIR="\$HOME/$PROJECTS_DIR/$SESSION"
  gcloud compute ssh "$INSTANCE" --tunnel-through-iap --zone="$ZONE" --project="$PROJECT" -- -t '
    if [ ! -f ~/.ccvm-setup-done ]; then
      bash ~/first-run-setup.sh
    fi
    mkdir -p ~/'"$PROJECTS_DIR/$SESSION"'
    cd ~/'"$PROJECTS_DIR/$SESSION"'
    if tmux has-session -t ='"$SESSION"' 2>/dev/null; then
      tmux attach-session -t ='"$SESSION"'
    else
      tmux new-session -d -s '"$SESSION"' -c ~/'"$PROJECTS_DIR/$SESSION"'
      tmux attach-session -t ='"$SESSION"' \; send-keys '"'$AGENT_CMD'"' Enter
    fi
    cd ~/'"$PROJECTS_DIR/$SESSION"'
    reset
    exec bash
  '
fi
